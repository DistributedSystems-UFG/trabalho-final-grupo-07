# ─────────────────────────────────────────────────────────────────────────────
# .env.dev.example
# Template para rodar toda a aplicação localmente via docker-compose-dev.yml
#
# Uso:
#   cp .env.dev.example .env
#   # gerar JWT_SECRET: python3 -c "import secrets; print(secrets.token_hex(32))"
#   docker compose -f docker-compose-dev.yml up -d --build
#
# ATENÇÃO: os hosts abaixo são nomes de serviços Docker (não localhost),
# pois todos os containers rodam na mesma rede trivia-net.
# A exceção é VITE_API_GATEWAY_HOST, que é resolvido pelo browser do usuário
# fora do Docker, por isso usa localhost.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Gerado com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=substitua-por-string-de-64-chars-gerada-aleatoriamente
JWT_EXPIRATION_SECONDS=86400

# ─── Endereços dos serviços (nomes dos serviços Docker) ───────────────────────
GAME_GRPC_ADDRESS=game-service:9090
USER_GRPC_ADDRESS=user-service:9091

# ─── Question DB — Shard A ────────────────────────────────────────────────────
DB_SHARD_A_HOST=db-shard-a
DB_SHARD_A_PORT=5432
DB_SHARD_A_NAME=questions_shard_a
DB_SHARD_A_USER=trivia
DB_SHARD_A_PASS=trivia

# ─── Question DB — Shard B ────────────────────────────────────────────────────
DB_SHARD_B_HOST=db-shard-b
DB_SHARD_B_PORT=5432
DB_SHARD_B_NAME=questions_shard_b
DB_SHARD_B_USER=trivia
DB_SHARD_B_PASS=trivia

# ─── User DB ──────────────────────────────────────────────────────────────────
DB_USERDB_NAME=trivia_users
DB_USERDB_USER=trivia
DB_USERDB_PASS=trivia_pass
DB_USER_PRIMARY_HOST=db-user-primary
DB_USER_PRIMARY_PORT=5432
DB_USER_REPLICA_HOST=db-user-replica
DB_USER_REPLICA_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
# Porta 29092: listener INTERNAL (comunicação entre containers na mesma rede Docker)
KAFKA_BROKERS=kafka:29092

# ─── Game Service ─────────────────────────────────────────────────────────────
GAME_QUESTION_TIMEOUT_MS=20000
GAME_ROOM_TTL_SECONDS=3600

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Resolvido pelo browser do usuário (fora do Docker) — usa localhost
VITE_API_GATEWAY_HOST=localhost:8000


GAME_SERVICE_WS_HOST=game-service
CORS_ORIGINS=["http://localhost"]